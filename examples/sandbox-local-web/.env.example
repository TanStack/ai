# Anthropic API key — both harnesses (Claude Code / OpenCode) use an Anthropic model.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Which coding agent runs in the sandbox: claude-code (default) | opencode
# HARNESS=claude-code

# Where it runs: docker (default, isolated) | local (host, no isolation)
# SANDBOX=docker

# Optional: a prebuilt Docker image with the harness CLI already installed,
# to skip the per-thread `npm install -g` on first create.
# SANDBOX_IMAGE=node:22
