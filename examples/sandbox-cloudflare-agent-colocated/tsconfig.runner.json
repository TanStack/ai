{
  // The in-container harness runner. A plain Node program bundled into the
  // container image with esbuild — type-checked against @types/node, NOT
  // @cloudflare/workers-types. The server + chat() wiring now ships from the
  // package's `/runner` entry; this app supplies only the adapter.
  "include": ["src/container-runner.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "types": ["node"],

    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "composite": true,
    "isolatedModules": true,

    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
