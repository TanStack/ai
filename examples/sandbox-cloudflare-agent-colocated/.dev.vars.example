# Local dev secrets for `wrangler dev`. Copy to `.dev.vars` and fill in.
# `.dev.vars` is gitignored; never commit real keys.

# Anthropic API key for the IN-CONTAINER `claude` CLI. The coordinator injects
# it into the container env (sandbox.setEnvVars) — never persisted to logs.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: an OAuth token instead of an API key (set one or the other).
# CLAUDE_CODE_OAUTH_TOKEN=
