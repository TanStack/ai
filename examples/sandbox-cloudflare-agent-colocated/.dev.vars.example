# Local dev secrets for `wrangler dev`. Copy to `.dev.vars` and fill in.
# `.dev.vars` is gitignored; never commit real keys.

# Anthropic API key for the IN-CONTAINER `claude` CLI. The coordinator injects
# it into the container env (sandbox.setEnvVars) — never persisted to logs.
# NOTE: in the co-located model only ANTHROPIC_API_KEY is wired into the
# container (see ContainerSandboxCoordinator.ensureRunner). Authenticating the
# CLI with an OAuth token instead would require extending ContainerCoordinatorEnv
# + the setEnvVars call to forward it.
ANTHROPIC_API_KEY=sk-ant-...
