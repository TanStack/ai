{
  // Worker + Durable Object code. Runs on the Cloudflare edge; uses
  // @cloudflare/workers-types globals (no node:http here).
  "include": ["src/worker.ts", "src/coordinator.ts", "src/run-log-do.ts", "src/protocol.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],

    /* Bundler mode (wrangler bundles with esbuild) */
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "composite": true,
    "isolatedModules": true,

    /* Strictness */
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
