# Anthropic API key — the in-sandbox `claude` CLI uses an Anthropic model.
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Vercel credentials — used to create the microVM sandbox the agent runs in.
# Create a token at: https://vercel.com/account/settings/tokens
VERCEL_TOKEN=
# Or use an OIDC token instead of VERCEL_TOKEN:
# VERCEL_OIDC_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
