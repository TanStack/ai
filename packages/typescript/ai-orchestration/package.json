  "description": "Generator-based workflows and orchestrators for TanStack AI",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TanStack/ai.git",
    "directory": "packages/typescript/ai-orchestration"
  },
  "keywords": ["ai", "tanstack", "workflow", "orchestration", "agents"],
  "type": "module",
