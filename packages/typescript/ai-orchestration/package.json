  },
  "peerDependencies": {
    "@tanstack/ai": "workspace:^"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/ai": "workspace:*",
    "@vitest/coverage-v8": "4.0.14",
    "vite": "^7.2.7",
    "zod": "^4.2.0"
  }
